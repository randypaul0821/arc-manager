{
   "background": {
      "service_worker": "background.js"
   },
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "ruleset_1",
         "path": "rules.json"
      } ]
   },
   "description": "Links your Embark account to ARCTracker for automatic sync",
   "externally_connectable": {
      "matches": [ "https://*.arctracker.io/*", "https://arctracker.io/*", "http://localhost/*" ]
   },
   "host_permissions": [ "http://127.0.0.1:49172/*", "http://localhost/*", "https://*.arctracker.io/*", "https://arctracker.io/*" ],
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "ARCTracker",
   "permissions": [ "declarativeNetRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
